# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Database (опционально, пока используется in-memory)
# DATABASE_URL=sqlite:///bot.db

# Admin IDs (через запятую, опционально)
# ADMIN_IDS=123456789,987654321

# SMS Services API Keys (добавьте при интеграции)
# SMSRU_API_KEY=your_smsru_key
# SMSC_LOGIN=your_login
# SMSC_PASSWORD=your_password

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
